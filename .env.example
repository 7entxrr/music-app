# Spotify Credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# YouTube Proxy (Required for YouTube search to work)
# Set this to a Cloudflare Worker URL or similar proxy that can bypass YouTube's anti-bot measures
# Without this, YouTube search will fail due to IP blocking
YOUTUBE_PROXY_URL=https://your-worker.your-subdomain.workers.dev

# Vercel (auto-generated, don't edit)
VERCEL_OIDC_TOKEN=...
